{
  "title": "Contract Service Dashboard",
  "tags": ["freelance", "contract-service"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "LogQL Error Rate",
      "targets": [{ "expr": "sum(count_over_time({service=\"contract-service\", level=\"ERROR\"}[1m]))", "legendFormat": "errors/min" }],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 }
    },
    {
      "type": "logs",
      "title": "LogQL Correlation Trace",
      "targets": [{ "expr": "{service=\"contract-service\"} | json | correlationId=~\".+\"", "legendFormat": "trace" }],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "LogQL RabbitMQ Audit",
      "targets": [
        { "expr": "sum(count_over_time({service=\"contract-service\"} |= \"Published\" [5m]))", "legendFormat": "published" },
        { "expr": "sum(count_over_time({service=\"contract-service\"} |= \"Consuming\" [5m]))", "legendFormat": "consumed" }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "PromQL HTTP Request Rate",
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{job=\"contract-service\"}[5m])) by (uri)", "legendFormat": "{{uri}}" }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "type": "timeseries",
      "title": "PromQL HTTP P99 Latency",
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"contract-service\"}[5m])) by (le, uri))", "legendFormat": "P99 {{uri}}" }],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "type": "timeseries",
      "title": "PromQL JVM Heap",
      "targets": [{ "expr": "jvm_memory_used_bytes{job=\"contract-service\", area=\"heap\"}", "legendFormat": "heap" }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    }
  ]
}
